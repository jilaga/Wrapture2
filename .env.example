# ─── Database (Neon Postgres) ─────────────────────────────────────────────
# Get this from Neon dashboard or Vercel Marketplace integration.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── Better Auth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Production: your full https URL. Dev: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Google OAuth (optional) ──────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Paystack (Nigeria payments) ──────────────────────────────────────────
# https://dashboard.paystack.com → Settings → API Keys & Webhooks
# Webhook URL: {NEXT_PUBLIC_APP_URL}/api/paystack/webhook
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""

# ─── WhatsApp (owner notification) ────────────────────────────────────────
# Cloud API: https://developers.facebook.com/docs/whatsapp/cloud-api
# Required for automatic owner notifications.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_OWNER_NUMBER="+234..."
# Public number for wa.me deep links + Contact page.
NEXT_PUBLIC_WHATSAPP_OWNER_NUMBER="+234..."

# ─── PostHog (analytics, optional) ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
