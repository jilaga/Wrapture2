# ─── Database (Neon Postgres) ─────────────────────────────────────────────
# Get this from Neon dashboard or Vercel Marketplace integration.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── Better Auth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Production: your full https URL. Dev: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Google OAuth (optional) ──────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Paystack (Nigeria payments) ──────────────────────────────────────────
# https://dashboard.paystack.com → Settings → API Keys & Webhooks
# Webhook URL: {NEXT_PUBLIC_APP_URL}/api/paystack/webhook
# Server-only key; the hosted payment page does not require a public key.
PAYSTACK_SECRET_KEY=""

# ─── WhatsApp (owner notification + ops dashboard) ────────────────────────
# Cloud API: https://developers.facebook.com/docs/whatsapp/cloud-api
# Required for outbound owner notifications and the inbound ops webhook.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_OWNER_NUMBER="+234..."
# Optional: extra staff numbers (comma-separated, E.164) allowed to issue ops commands.
WHATSAPP_STAFF_NUMBERS=""
# Optional: WhatsApp Business Account id — only needed for advanced template mgmt.
WHATSAPP_BUSINESS_ACCOUNT_ID=""
# Required for inbound webhook verification handshake with Meta.
# Pick any random string and paste the same value into the Meta webhook config.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
# Public number for wa.me deep links + Contact page.
NEXT_PUBLIC_WHATSAPP_OWNER_NUMBER="+234..."

# ─── PostHog (analytics, optional) ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
